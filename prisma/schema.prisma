generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (Auth.js) ────────────────────────────────────────────────

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  username          String?            @unique
  accounts          Account[]
  sessions          Session[]
  schedules         WorkoutSchedule[]
  previousUsernames PreviousUsername[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PreviousUsername {
  id        String   @id @default(cuid())
  username  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  changedAt DateTime @default(now())

  @@index([username])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Exercise Library ───────────────────────────────────────────────

model MuscleGroup {
  id           String     @id @default(cuid())
  name         String     @unique
  displayOrder Int        @default(0)
  exercises    Exercise[] @relation("PrimaryMuscle")
  secondaryOf  Exercise[] @relation("SecondaryMuscles")
}

enum WeightUnit {
  KG
  LBS
}

enum DistanceUnit {
  KM
  MILES
}

enum WorkoutType {
  STRENGTH
  CARDIO
}

model AppSettings {
  id                  String       @id @default("default")
  defaultWeightUnit   WeightUnit   @default(KG)
  defaultDistanceUnit DistanceUnit @default(KM)
}

enum EquipmentType {
  BARBELL
  DUMBBELL
  MACHINE
  CABLE
  BODYWEIGHT
  SMITH_MACHINE
  EZ_BAR
  KETTLEBELL
  RESISTANCE_BAND
  OTHER
}

model Exercise {
  id                    String                    @id @default(cuid())
  name                  String                    @unique
  description           String?
  equipmentType         EquipmentType             @default(OTHER)
  imageUrl              String?
  exerciseDbId          String?                   @unique
  primaryMuscleGroup    MuscleGroup               @relation("PrimaryMuscle", fields: [primaryMuscleGroupId], references: [id])
  primaryMuscleGroupId  String
  secondaryMuscleGroups MuscleGroup[]             @relation("SecondaryMuscles")
  programExercises      ProgramWorkoutExercise[]
  sessionExercises      WorkoutSessionExercise[]
  notes                 ExerciseNote[]
  personalRecords       PersonalRecord[]
  weightUnit            WeightUnit?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([primaryMuscleGroupId])
}

// ─── Programs ───────────────────────────────────────────────────────

enum ProgramType {
  PERIODIZED
  SIMPLE
}

model Program {
  id                     String           @id @default(cuid())
  name                   String
  description            String?
  type                   ProgramType      @default(SIMPLE)
  defaultRestSeconds     Int              @default(90)
  defaultWarmUpSets      Int              @default(1)
  defaultWorkingSets     Int              @default(3)
  defaultWarmUpPercent   Float            @default(0.6)
  isActive               Boolean          @default(false)
  phases                 ProgramPhase[]
  workouts               ProgramWorkout[]
  sessions               WorkoutSession[]
  cardioActivities       CardioActivity[]
  schedules              WorkoutSchedule[] @relation("ScheduleProgram")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model ProgramPhase {
  id            String           @id @default(cuid())
  program       Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId     String
  name          String
  description   String?
  orderIndex    Int
  durationWeeks Int              @default(4)
  workouts      ProgramWorkout[]

  @@index([programId])
}

model ProgramWorkout {
  id                    String                   @id @default(cuid())
  program               Program                  @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId             String
  phase                 ProgramPhase?            @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  phaseId               String?
  name                  String
  dayIndex              Int
  orderIndex            Int
  workoutType           WorkoutType              @default(STRENGTH)
  targetDistanceMeters  Float?
  targetDurationSeconds Int?
  targetPaceSecondsPerKm Float?
  cardioNotes           String?
  exercises             ProgramWorkoutExercise[]
  sessions              WorkoutSession[]
  cardioActivities      CardioActivity[]
  scheduledWorkouts     ScheduledWorkout[]

  @@index([programId])
  @@index([phaseId])
}

model ProgramWorkoutExercise {
  id               String              @id @default(cuid())
  programWorkout   ProgramWorkout      @relation(fields: [programWorkoutId], references: [id], onDelete: Cascade)
  programWorkoutId String
  exercise         Exercise            @relation(fields: [exerciseId], references: [id])
  exerciseId       String
  orderIndex       Int
  warmUpSets       Int?
  workingSets      Int?
  warmUpPercent    Float?
  targetReps       String?
  restSeconds      Int?
  sets             ProgramWorkoutSet[]

  @@index([programWorkoutId])
  @@index([exerciseId])
}

model ProgramWorkoutSet {
  id                       String                 @id @default(cuid())
  programWorkoutExercise   ProgramWorkoutExercise @relation(fields: [programWorkoutExerciseId], references: [id], onDelete: Cascade)
  programWorkoutExerciseId String
  setType                  SetType                @default(WORKING)
  targetWeight             Float?
  targetReps               String?
  restSeconds              Int                    @default(90)
  orderIndex               Int

  @@index([programWorkoutExerciseId])
}

// ─── Workout Sessions ───────────────────────────────────────────────

enum SessionStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
}

model WorkoutSession {
  id               String                   @id @default(cuid())
  name             String?
  program          Program?                 @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId        String?
  programWorkout   ProgramWorkout?          @relation(fields: [programWorkoutId], references: [id], onDelete: SetNull)
  programWorkoutId String?
  status              SessionStatus            @default(PLANNED)
  startedAt           DateTime?
  endedAt             DateTime?
  pausedAt            DateTime?
  totalPausedSeconds  Int                      @default(0)
  notes               String?
  exercises         WorkoutSessionExercise[]
  scheduledWorkout  ScheduledWorkout?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([programId])
  @@index([programWorkoutId])
  @@index([startedAt])
  @@index([status])
}

model WorkoutSessionExercise {
  id               String          @id @default(cuid())
  workoutSession   WorkoutSession  @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  workoutSessionId String
  exercise         Exercise        @relation(fields: [exerciseId], references: [id])
  exerciseId       String
  orderIndex       Int
  sets             WorkoutSet[]
  notes            ExerciseNote[]

  @@index([workoutSessionId])
  @@index([exerciseId])
}

enum SetType {
  WARM_UP
  WORKING
}

model WorkoutSet {
  id                       String                 @id @default(cuid())
  sessionExercise          WorkoutSessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)
  sessionExerciseId        String
  setType                  SetType                @default(WORKING)
  weight                   Float?
  reps                     Int?
  orderIndex               Int
  completedAt              DateTime?

  @@index([sessionExerciseId])
}

// ─── Notes ──────────────────────────────────────────────────────────

model ExerciseNote {
  id                       String                  @id @default(cuid())
  exercise                 Exercise                @relation(fields: [exerciseId], references: [id])
  exerciseId               String
  sessionExercise          WorkoutSessionExercise? @relation(fields: [sessionExerciseId], references: [id], onDelete: SetNull)
  sessionExerciseId        String?
  content                  String
  isPinned                 Boolean                 @default(false)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  @@index([exerciseId])
  @@index([sessionExerciseId])
}

// ─── Personal Records ───────────────────────────────────────────────

model PersonalRecord {
  id               String          @id @default(cuid())
  exercise         Exercise        @relation(fields: [exerciseId], references: [id])
  exerciseId       String
  weight           Float
  reps             Int
  estimated1RM     Float
  achievedAt       DateTime        @default(now())
  workoutSessionId String?

  @@index([exerciseId])
  @@index([achievedAt])
}

// ─── Workout Schedule ──────────────────────────────────────────────

enum ScheduledWorkoutStatus {
  SCHEDULED
  COMPLETED
  SKIPPED
}

model WorkoutSchedule {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId         String
  program           Program            @relation("ScheduleProgram", fields: [programId], references: [id], onDelete: Cascade)
  startDate         DateTime           @db.Date
  trainingDays      Int[]
  isActive          Boolean            @default(true)
  googleCalendarId  String?
  scheduledWorkouts ScheduledWorkout[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
  @@index([programId])
}

model ScheduledWorkout {
  id               String                 @id @default(cuid())
  schedule         WorkoutSchedule        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId       String
  programWorkout   ProgramWorkout         @relation(fields: [programWorkoutId], references: [id])
  programWorkoutId String
  scheduledDate    DateTime               @db.Date
  originalDate     DateTime?              @db.Date
  status           ScheduledWorkoutStatus @default(SCHEDULED)
  session          WorkoutSession?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId        String?                @unique
  googleEventId    String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([scheduleId])
  @@index([scheduledDate])
  @@index([status])
  @@index([programWorkoutId])
}

// ─── Strava Integration ────────────────────────────────────────────

model StravaConnection {
  id              String   @id @default("default")
  stravaAthleteId Int
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  scope           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Cardio Activities ─────────────────────────────────────────────

model CardioActivity {
  id                    String          @id @default(cuid())
  name                  String
  activityType          String          @default("Run")

  // Core metrics (stored in metric units)
  distanceMeters        Float
  movingTimeSeconds     Int
  elapsedTimeSeconds    Int

  // Pace & speed
  averagePaceSecsPerKm  Float?
  averageSpeedMps       Float?
  maxSpeedMps           Float?

  // Elevation
  elevationGainMeters   Float?
  elevationLossMeters   Float?

  // Heart rate
  averageHeartrate      Float?
  maxHeartrate          Float?

  // Cadence & calories
  averageCadence        Float?
  calories              Float?

  // Rich data (JSON)
  splits                Json?
  laps                  Json?
  bestEfforts           Json?
  summaryPolyline       String?

  // Source tracking
  source                String          @default("manual")
  stravaActivityId      BigInt?         @unique

  // Program integration
  programWorkout        ProgramWorkout? @relation(fields: [programWorkoutId], references: [id], onDelete: SetNull)
  programWorkoutId      String?
  program               Program?        @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId             String?

  // Timestamps
  activityDate          DateTime
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([activityDate])
  @@index([stravaActivityId])
  @@index([programWorkoutId])
  @@index([source])
}
